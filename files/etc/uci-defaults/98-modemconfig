#!/bin/sh

# check soft upgrade
[ -f /etc/.config.lock ] && exit 0

board="$(cat /tmp/sysinfo/board_name)"
RES=/usr/share/modeminfo/modem.list

# ============================================================
# COMMON
# ============================================================

args(){
	echo "$#"
}

# default UCI config for modeminfo and smstools3
default_setup(){
	uci set modeminfo.@general[0]=general
	uci set modeminfo.@general[0].index='1'
	uci set modeminfo.@general[0].decimail='1'
	uci set smstools3.@sms[0]=sms
	uci set smstools3.@sms[0].decode_utf='1'
	uci set smstools3.@sms[0].storage='temporary'
	uci set smstools3.@sms[0].loglevel='5'
}


disable_mm(){
	for m in stop disable; do
		/etc/init.d/modemmanager ${m}
	done
}

# ============================================================
# MODEMCONFIG (modemmanager / mmcli)
# ============================================================

NODE_MM=MODEMCONFIG

read_modem_list(){
	MODEMS=$(jsonfilter -s "$(mmcli -L -J)" -e "@['modem-list'][*]" | sort)
}

atinout_cfg_nl678(){
cat << 'EOF' >> /etc/atcommands.user
Demo command "ATI";ATI
NL678 - to NCM(23);AT+GTUSBMODE=23
NL678 - to QMI(22);AT+GTUSBMODE=22
NL678 - to QMI(17);AT+GTUSBMODE=17
NL678 - reboot modem;AT+CFUN=1,1
EOF
}

atinout_cfg_l850(){
cat << 'EOF' >> /etc/atcommands.user
Demo command "ATI";ATI
L850 - to MBIM(7);AT+GTUSBMODE=7
L850 - to NCM(0);AT+GTUSBMODE=0
L850 - reboot modem;AT+CFUN=15
EOF
}

atinout_msg(){
	logger -t "$NODE_MM" "WARNING: Generate atinout commands for change USB-composition"
	logger -t "$NODE_MM" "WARNING: Go to \"Modem\" -> \"AT Commands\" and select modem mode."
	logger -t "$NODE_MM" "WARNING: Select AT-port and put command to modem"
	logger -t "$NODE_MM" "WARNING: For autoconfig reset router to defaults."
}

failed_msg(){
	logger -t "$NODE_MM" "WARNING: But modem is failed with reason: \"${FAILED}\". Functionality is disabled."
	logger -t "$NODE_MM" "WARNING: Eliminate the failure cause and enable check ping,"
	logger -t "$NODE_MM" "WARNING: Network interface and SMS messaging manually"
	logger -t "$NODE_MM" "WARNING: or reset device to defaults, for automatic setup."
}

standby_modems(){
	i=0
	while true; do
		! [ "$MODEMS" ] && {
			read_modem_list
			[ $i -gt 30 ] && { exit 0; }
		} || {
			break
		}
		sleep 4
		i=$(($i+1))
	done
}

get_modem_param(){
	jsonfilter -s "$(mmcli -m ${m} -J)" \
		-e "DEVICE=$['modem']['generic']['device']" \
		-e "PORTS=$['modem']['generic']['ports'][*]" \
		-e "OPERATOR=$['modem']['3gpp']['operator-code']" \
		-e "FAILED=$['modem']['generic']['state-failed-reason']"
}

modeminfo_conf(){
	case $ATPORT in
		*ttyUSB*|*ttyACM*)
			uci add modeminfo modeminfo
			uci set modeminfo.@modeminfo[-1].device=/dev/${ATPORT}
			case $FAMILY in
				*DELL*|*QUALCOMM*) uci set modeminfo.@modeminfo[-1].mmcli_name=1 ;;
			esac
		;;
		*cdc-wdm*)
			uci add modeminfo modeminfo
			uci set modeminfo.@modeminfo[-1].qmi_mode=1
			uci set modeminfo.@modeminfo[-1].device_qmi=/dev/${ATPORT}
		;;
	esac
}

mm_smstools3_conf(){
	uci set smstools3.$ifmodemname=modem
	uci set smstools3.$ifmodemname.device=/dev/${SMSPORT}
	[ "$FAILED" = "--" ] && uci set smstools3.$ifmodemname.enable=1
}

iface_modemmanager(){
	uci set network.$ifmodemname=interface
	uci set network.$ifmodemname.proto=modemmanager
	uci set network.$ifmodemname.device=$DEVICE
	uci set network.$ifmodemname.iptype=ipv4
	uci set network.$ifmodemname.apn=$APN
	uci add_list network.$ifmodemname.allowedauth=none
	uci set network.$ifmodemname.signalrate='10'
	uci set network.$ifmodemname.metric=${mn}00
	[ "$FAILED" = "--" ] || uci set network.$ifmodemname.disabled='1'
}

mmconfig_setup(){
	uci set mmconfig.$ifmodemname=modem
	uci set mmconfig.$ifmodemname.device=$DEVICE
}

mm_pingcontrol_setup(){
	uci set pingcontrol.$ifmodemname=pingcontrol
	[ "$FAILED" = "--" ] && uci set pingcontrol.$ifmodemname.enabled='1'
	uci set pingcontrol.$ifmodemname.check_period='60'
	uci set pingcontrol.$ifmodemname.ping_silent='1'
	uci set pingcontrol.$ifmodemname.iface=$ifmodemname
	uci set pingcontrol.$ifmodemname.sw_before_modres='2'
	uci set pingcontrol.$ifmodemname.sw_before_sysres='5'
	uci set pingcontrol.$ifmodemname.testip='dns.yandex'
}

iface_mm_bearer(){
	case $VIDPID in
		12d11*) uci set network.$ifmodemname.init_epsbearer=none ;;
		*2cb7010a*)
			uci set network.$ifmodemname.init_epsbearer=none
			atinout_cfg_nl678
			logger -t "$NODE_MM" "WARNING: modem in NCM mode, but will work QMI. Please setup modem mode AT-command"
			atinout_msg
		;;
		*8087095a*)
			atinout_cfg_l850
			logger -t "$NODE_MM" "WARNING: modem in XMM mode, check modem model, if model L850 please setup modem mode AT-command"
			atinout_msg
		;;
		*) uci set network.$ifmodemname.init_epsbearer=default ;;
	esac
}

configure_mm_uci(){
	ARGSLENMODEM=$(args $MODEMS)
	[ $ARGSLENMODEM -eq 0 ] && {
		logger -t "$NODE_MM" "WARNING: modems not found in system"
		return 0
	}
	default_setup
	NOT_SUPPORT_MM=1
	L850=0

	for m in $MODEMS; do
		mmcli -m ${m} -e
		sleep 5
		eval $(echo $(get_modem_param) | sed -e 's/export//g')
		VID=$(cat ${DEVICE}/idVendor)
		PID=$(cat ${DEVICE}/idProduct)
		VIDPID="${VID}${PID}"
		[ -r ${RES} ] && {
			[ "$VID" -a "$PID" ] && {
				FAMILY=$(awk -F [\;] '/'$VIDPID'/{print toupper($2)}' $RES)
				logger -t "$NODE_MM" "Found family $FAMILY modem: ${VID}:${PID}"
			}
			[ "$FAILED" = "--" ] || failed_msg
		}
		case $OPERATOR in
			25001) APN=internet.mts.ru ;;
			25011) APN=internet.yota ;;
			25020) APN=internet.tele2.ru ;;
			25099) APN=internet.beeline.ru ;;
			*) APN=internet ;;
		esac
		make_ifname
		[ "x${VIDPID}" != "x" ] && {
			case $VIDPID in
				8087095a|2c7c6000|2c7c6026|\
				12864e3c|19d20532|305a1415|\
				0e8d7126|0e8d7127|2cd20001|\
				2cd20004|19d21404|19d21424)
					continue
				;;
				2cb70007)
					L850=1
					NOT_SUPPORT_MM=0
				;;
				*)
					NOT_SUPPORT_MM=0
				;;
			esac
		} || {
			NOT_SUPPORT_MM=1
		}
		case $FAMILY in
			SIERRA|THALES) ATPORT=$(echo "$PORTS" | awk '{for (i=1; i<=NF; i++) if($i ~ /cdc-wdm/) {print $i; exit}}') ;;
			*) ATPORT=$(echo "$PORTS" | awk '{ for (i=1; i<=NF; i++) { if ($(i+1) == "(at)") { print $i; break; }}}') ;;
		esac
		[ "x${m}" != "x" ] && [ "$NOT_SUPPORT_MM" = "0" ] && {
			iface_modemmanager
			iface_mm_bearer
			mmconfig_setup
			mm_pingcontrol_setup
			uci add_list firewall.@zone[1].network=$ifmodemname
			logger -t "$NODE_MM" "Setting up modem interface \"$ifmodemname\" with APN: ${APN}"
		} || {
			logger -t "$NODE_MM" "WARNING: modem: ${VID}:${PID} not supported by modemmanager."
			logger -t "$NODE_MM" "WARNING: Please manualy configure interface."
		}
		! [ "$ATPORT" = "" ] && {
			modeminfo_conf
			case $ATPORT in
				ttyUSB*)
					SMSPORT=${ATPORT%?}$((${ATPORT: -1}+1))
					mm_smstools3_conf
					case $VIDPID in
						2cb70104|2cb70109)
							uci set smstools3.$ifmodemname.net_check='0'
							uci set smstools3.$ifmodemname.sig_check='1'
						;;
					esac
				;;
				ttyACM*)
					SMSPORT=${ATPORT%?}$((${ATPORT: -1}+2))
					mm_smstools3_conf
					uci set smstools3.$ifmodemname.net_check='0'
					uci set smstools3.$ifmodemname.sig_check='1'
				;;
			esac
		}
		mn=$(($mn+1))
		MWAN_IFACES="$MWAN_IFACES $ifmodemname"
		unset ATPORT FAMILY
	done

	[ ! -n "$SMSPORT" -a "$NOT_SUPPORT_MM" = "0" ] && {
		for i in smstools3 luci-sms; do
			for a in stop disable; do
				/etc/init.d/${i} ${a}
			done
		done
		logger -t "$NODE_MM" "WARNING: Any installed modems no have two or more AT-ports"
		logger -t "$NODE_MM" "WARNING: SMS messaging funcionality disabled."
		logger -t "$NODE_MM" "WARNING: Please manually configure service."
	}
	[ "$L850" = "0" ] && {
		[ -x /etc/init.d/fixmodem ] && /etc/init.d/fixmodem disable
	}
	[ "$NOT_SUPPORT_MM" = "1" ] && {
		logger -t "$NODE_MM" "WARNING: Any installed modems not supported by autoconfiguration."
		logger -t "$NODE_MM" "WARNING: Mobile services is stopped."
		logger -t "$NODE_MM" "WARNING: Please manually configure it."
		for i in smstools3 luci-sms modemmanager; do
			for a in stop disable; do
				/etc/init.d/${i} ${a}
			done
		done
		atinout_cfg_l850
		atinout_cfg_nl678
		atinout_msg
	} || {
		logger -t "$NODE_MM" "Modem interface(s) setup complete."
	}
}

mm_stuff(){
	> /etc/config/mmconfig
	standby_modems
	configure_mm_uci
}


# ============================================================
# XMMCONFIG (Fibocom L850 / FM350 via xmm proto)
# ============================================================

NODE_XMM=XMMCONFIG

xmm_uci_config(){
	logger -t "$NODE_XMM" "Found device $FAMILY (${vid}:${pid}) with port /dev/${device} ($interface)"
	uci set network.$ifmodemname=interface
	uci set network.$ifmodemname.proto=xmm
	uci set network.$ifmodemname.device=/dev/${device}
	uci set network.$ifmodemname.apn=internet
	uci set network.$ifmodemname.metric=${mn}00
	[ "$FAILED" = "--" ] || uci set network.$ifmodemname.disabled='1'
	uci add_list firewall.@zone[1].network=$ifmodemname
	uci add modeminfo modeminfo
	uci set modeminfo.@modeminfo[-1].device=/dev/${device}
	uci set pingcontrol.$ifmodemname=pingcontrol
	[ "$FAILED" = "--" ] && uci set pingcontrol.$ifmodemname.enabled='1'
	uci set pingcontrol.$ifmodemname.check_period='60'
	uci set pingcontrol.$ifmodemname.ping_silent='1'
	uci set pingcontrol.$ifmodemname.iface=$ifmodemname
	uci set pingcontrol.$ifmodemname.sw_before_modres='2'
	uci set pingcontrol.$ifmodemname.sw_before_sysres='5'
	uci set pingcontrol.$ifmodemname.testip='dns.yandex'
	uci commit network
	uci commit firewall
	uci commit modeminfo
	uci commit pingcontrol
	sleep 3
	ifup $ifmodemname
}

xmm_smstools_uci_config(){
	SMSPORT=/dev/${device%?}$((${device: -1}+2))
	logger -t "$NODE_XMM" "Start SMS messaging configure with port $SMSPORT"
	uci set smstools3.$ifmodemname=modem
	uci set smstools3.$ifmodemname.device=$SMSPORT
	uci set smstools3.$ifmodemname.net_check='0'
	uci set smstools3.$ifmodemname.sig_check='1'
	[ "$FAILED" = "--" ] && uci set smstools3.$ifmodemname.enable=1
}

check_sim(){
	gcom -d /dev/${device} -s /etc/gcom/setpin.gcom > /dev/null 2>&1 && FAILED="--" || FAILED=OK
}

get_usb_info(){
	device="$1"
	if [ -e "/sys/class/tty/${device}" ]; then
		tty_path=$(readlink -f "/sys/class/tty/${device}" 2>/dev/null)
		interface_path=""
		current_path="$tty_path"
		while [ -n "$current_path" ] && [ "$current_path" != "/" ]; do
			if [ -f "${current_path}/bInterfaceNumber" ]; then
				interface_path="$current_path"
				break
			fi
			current_path=$(dirname "$current_path")
		done
		if [ -n "$interface_path" ]; then
			usb_device_path=$(dirname "$interface_path")
			while [ -n "$usb_device_path" ] && [ "$usb_device_path" != "/" ]; do
				if [ -f "${usb_device_path}/idVendor" ] && [ -f "${usb_device_path}/idProduct" ]; then
					break
				fi
				usb_device_path=$(dirname "$usb_device_path")
			done
			if [ -n "$usb_device_path" ] && [ "$usb_device_path" != "/" ]; then
				vid=$(cat "${usb_device_path}/idVendor" 2>/dev/null)
				pid=$(cat "${usb_device_path}/idProduct" 2>/dev/null)
				interface=$(cat "${interface_path}/bInterfaceNumber" 2>/dev/null)
				case ${vid}${pid} in
					8087095a)
						case $interface in
							00)
								FAMILY="Fibocom L850/L850 NCM Modem"
								make_ifname
								mn=$((mn+1))
								MWAN_IFACES="$MWAN_IFACES $ifmodemname"
								check_sim
								xmm_uci_config
								xmm_smstools_uci_config
							;;
						esac
					;;
					0e8d7126)
						FAMILY="Fibocom FM350 NCM Modem"
						case $interface in
							04)
								make_ifname
								mn=$((mn+1))
								MWAN_IFACES="$MWAN_IFACES $ifmodemname"
								check_sim
								xmm_uci_config
							;;
						esac
					;;
					0e8d7127)
						FAMILY="Fibocom FM350 NCM Modem"
						case $interface in
							06)
								make_ifname
								mn=$((mn+1))
								MWAN_IFACES="$MWAN_IFACES $ifmodemname"
								check_sim
								xmm_uci_config
							;;
						esac
					;;
				esac
				return 0
			fi
		fi
	fi
	return 1
}

xmm_stuff(){
	default_setup
	found_devices=0
	for dev_base in ttyUSB ttyACM; do
		dev_num=0
		while true; do
			dev="/dev/${dev_base}${dev_num}"
			if [ -e "$dev" ]; then
				device_name="${dev_base}${dev_num}"
				if get_usb_info "$device_name"; then
					found_devices=$((found_devices + 1))
				fi
				dev_num=$((dev_num + 1))
			else
				if [ $dev_num -eq 0 ]; then
					for alt_dev in "/dev/${dev_base}"*; do
						if [ -e "$alt_dev" ] && [ "$alt_dev" != "/dev/${dev_base}*" ]; then
							device_name=$(basename "$alt_dev2")
							if get_usb_info "$device_name"; then
								found_devices=$((found_devices + 1))
							fi
						fi
					done
				fi
				break
			fi
		done
	done
}


# ============================================================
# QMICONFIG (uqmi / QMI proto — only b4com boards)
# ============================================================

NODE_QMI=QMICONFIG

check_mm(){
	[ -x /usr/bin/mmcli ] && {
		STATUS=$(/etc/init.d/modemmanager status > /dev/null 2>&1 && echo $?)
		case $STATUS in
			0) disable_mm ;;
		esac
	}
}

get_at_port(){
	PORTS=$(ls $(readlink -f /sys/class/usbmisc/${d}/../../../)/*:*/bInterfaceNumber)
	for i in $PORTS; do
		BNUM=$(cat $i)
		case $BNUM in
			$IFACE_NUM)
				ATPORT=$(ls -1 ${i%/*}/ | grep tty)
				SMSPORT=${ATPORT%?}$((${ATPORT: -1}+1))
			;;
		esac
	done
}

qmi_ports(){
	FAMILY=$1
	case $FAMILY in
		QUECTEL) IFACE_NUM=02 ;;
		DELL) IFACE_NUM=02 ;;
		MEIGLINK) IFACE_NUM=01 ;;
		FIBOCOM)
			case $PID in
				104) IFACE_NUM=01 ;;
				109) IFACE_NUM=00 ;;
			esac
		;;
		*)
			logger -t "${NODE_QMI}" "Modem family not supported"
			return 1
		;;
	esac
}

serving_modem(){
	SERVING=$1
	jsonfilter -s "$SERVING" \
		-e "MCC=$['plmn_mcc']" \
		-e "MNC=$['plmn_mnc']" \
		-e "DESC=$['plmn_description']"
}

modem_iface_setup(){
	uci set network.$ifmodemname=interface
	uci set network.$ifmodemname.proto=qmi
	uci set network.$ifmodemname.device=$DEVICE
	uci set network.$ifmodemname.iptype=ipv4
	uci set network.$ifmodemname.apn=$APN
	uci set network.$ifmodemname.metric=${mn}00
	[ "$SIM" = "ready" ] || uci set network.$ifmodemname.disabled='1'
	uci add_list firewall.@zone[1].network=$ifmodemname
}

qmi_modeminfo_setup(){
	case $ATPORT in
		*ttyUSB*|*ttyACM*)
			uci add modeminfo modeminfo
			uci set modeminfo.@modeminfo[-1].device=/dev/${ATPORT}
			case $FAMILY in
				*DELL*|*QUALCOMM*) uci set modeminfo.@modeminfo[-1].mmcli_name=1 ;;
			esac
		;;
		*cdc-wdm*)
			uci add modeminfo modeminfo
			uci set modeminfo.@modeminfo[-1].qmi_mode=1
			uci set modeminfo.@modeminfo[-1].qmi_proxy=1
			uci set modeminfo.@modeminfo[-1].device_qmi=/dev/${ATPORT}
		;;
	esac
}

qmi_pingcontrol_setup(){
	uci set pingcontrol.$ifmodemname=pingcontrol
	[ "$SIM" = "ready" ] && uci set pingcontrol.$ifmodemname.enabled='1'
	uci set pingcontrol.$ifmodemname.check_period='60'
	uci set pingcontrol.$ifmodemname.ping_silent='1'
	uci set pingcontrol.$ifmodemname.iface=$ifmodemname
	uci set pingcontrol.$ifmodemname.sw_before_modres='2'
	uci set pingcontrol.$ifmodemname.sw_before_sysres='5'
	uci set pingcontrol.$ifmodemname.testip='dns.yandex'
}

qmi_smstools3_setup(){
	uci set smstools3.$ifmodemname=modem
	uci set smstools3.$ifmodemname.device=/dev/${SMSPORT}
	[ "$SIM" = "ready" ] && uci set smstools3.$ifmodemname.enable=1
}

qmi_device(){
	CDC_WDM_DEV=$(ls /sys/class/usbmisc/)
	ARGSLENMODEM=$(args $CDC_WDM_DEV)

	[ "$ARGSLENMODEM" -eq "0" ] && {
		logger -t "$NODE_QMI" "WARNING: modems not found in system"
		return 1
	} || {
		default_setup
	}
	for d in $CDC_WDM_DEV; do
		make_ifname
		case $d in
			cdc-wdm*)
				ls $(readlink -f /sys/class/usbmisc/${d}/../../driver/module/drivers/) | grep -i qmi > /dev/null 2>&1
				case $? in
					0)
						VID=$(cat $(readlink -f /sys/class/usbmisc/${d}/../../../idVendor))
						PID=$(cat $(readlink -f /sys/class/usbmisc/${d}/../../../idProduct))
						mn=$(($mn+1))
						DEVICE=/dev/${d}
						[ -r ${RES} ] && {
							[ "$VID" -a "$PID" ] && {
								FAMILY=$(awk -F [\;] '/'${VID}${PID}'/{print toupper($2)}' $RES)
								logger -t "$NODE_QMI" "Found family $FAMILY modem: ${VID}:${PID}"
								qmi_ports $FAMILY
								logger -t "$NODE_QMI" "Setting up services for $ifmodemname:"
								get_at_port
								logger -t "$NODE_QMI" "Data: ${DEVICE}"
								logger -t "$NODE_QMI" "Metric: /dev/${ATPORT}"
								logger -t "$NODE_QMI" "SMS: /dev/${SMSPORT}"
								SIM=$(uqmi -d ${DEVICE} --uim-get-sim-state | jsonfilter -e '@["card_application_state"]')
								[ $SIM = "ready" ] || {
									logger -t "$NODE_QMI" "WARNING: $ifmodemname SIM is missing. Disabled next services:"
									logger -t "$NODE_QMI" "- Bring up boot modem interface."
									logger -t "$NODE_QMI" "- SMS messaging."
									logger -t "$NODE_QMI" "- Ping alive link."
									logger -t "$NODE_QMI" "Plese setting up it manually after clearing SIM error reason."
								}
								SERVING="$(uqmi -d ${DEVICE} --get-serving-system)"
								eval $(serving_modem "$SERVING")
								case $MCC in
									250)
										case $MNC in
											1) APN=internet.mts.ru ;;
											11) APN=internet.yota ;;
											20) APN=internet.tele2.ru ;;
											99) APN=internet.beeline.ru ;;
											*) APN=internet ;;
										esac
									;;
									*) APN=internet ;;
								esac
								modem_iface_setup
								qmi_modeminfo_setup
								qmi_pingcontrol_setup
								qmi_smstools3_setup
							}
						}
						MWAN_IFACES="$MWAN_IFACES $ifmodemname"
						unset ATPORT FAMILY VID PID
					;;
					*) logger -t "$NODE_QMI" "Device /dev/${d} is not QMI. Skip." ;;
				esac
			;;
		esac
	done
}

qmi_stuff(){
	[ -x /sbin/uqmi ] || {
		logger -t "$NODE_QMI" "WARNING: UQMI not found in system!"
		return 1
	}
	check_mm
	sleep 10
	qmi_device
}


# ============================================================
# MWAN3
# ============================================================

setup_mwan3(){
	[ -x /usr/sbin/mwan3 -a -x /usr/share/mwan3_gen.sh ] && {
		logger -t "$NODE" "Generate config for MWAN3."
		MODEMLEN=$(uci show network | awk '/modem/ && /interface/{len++} END {print len}')
		if [ "$MODEMLEN" -eq "1" ]; then
			MWAN3_POLICY="default"
		elif [ "$MODEMLEN" -ge "2" ]; then
			MWAN3_POLICY="balanced"
		fi
		case $board in
			beeline,smartbox-turbo-plus|\
			beeline,smartbox-giga|\
			beeline,smartbox-flash)
				LEDS="-l blue:wan -o red:status"
			;;
			cudy,tr3000-v1)
				LEDS="-l white:status -o red:power"
			;;
			huastlink,hc-g60)
				LEDS="-l blue:status -o green:status"
			;;
			huastlink,hc-g60-v1|\
			huastlink,hc-g80|\
			zbtlink,zbt-wg1608-16m|\
			zbtlink,zbt-wg1608-32m)
				LEDS="-l green:wwan"
			;;
			zbtlink,zbt-wg2107)
				LEDS="-l green:wwan1 green:wwan2"
			;;
			zbtlink,zbt-cpe2801-32m)
				LEDS="-l green:wwan1 green:wwan2"
				PORT_WAN=0
			;;
			zbtlink,zbt-z8102ax-nand-64m|\
			zbtlink,zbt-z8102ax-nand-all|\
			zbtlink,zbt-z8102ax-v2|\
			zbtlink,zbt-z8102ax-emmc)
				LEDS="-l blue:usb-0 blue:usb-1"
			;;
			zbtlink,zbt-z8109ax-nand-64m|\
			zbtlink,zbt-z8109ax-nand-128m|\
			zbtlink,zbt-z8109ax-nand-all)
				LEDS="-l green:modem1 green:modem2 green:modem3 green:modem4"
			;;
			*) LEDS="false" ;;
		esac
		[ "$LEDS" != "false" -a -x /usr/share/mwan3_led_config.sh ] && {
			/usr/share/mwan3_led_config.sh -i ${MWAN_IFACES:=modem} ${LEDS} > /etc/config/mwan3_led
		} || {
			> /etc/config/mwan3_led
		}
		[ "$PORT_WAN" = "0" ] || MWAN_IFACES="wan $MWAN_IFACES"
		/usr/share/mwan3_gen.sh -i ${MWAN_IFACES:=modem} -p $MWAN3_POLICY > /etc/config/mwan3
		logger -t "$NODE" "MWAN3: default policy is \"$MWAN3_POLICY\". Restart service to take effect."
		/etc/init.d/mwan3 restart
	}
}


# ============================================================
# DETECT — count all modems in system
# ============================================================
count_xmm_modems(){
	XMM_COUNT=0
	for dev_base in ttyUSB ttyACM; do
		dev_num=0
		while true; do
			dev="/dev/${dev_base}${dev_num}"
			[ -e "$dev" ] || break
			device_name="${dev_base}${dev_num}"
			if [ -e "/sys/class/tty/${device_name}" ]; then
				tty_path=$(readlink -f "/sys/class/tty/${device_name}" 2>/dev/null)
				current_path="$tty_path"
				interface_path=""
				while [ -n "$current_path" ] && [ "$current_path" != "/" ]; do
					if [ -f "${current_path}/bInterfaceNumber" ]; then
						interface_path="$current_path"
						break
					fi
					current_path=$(dirname "$current_path")
				done
				if [ -n "$interface_path" ]; then
					usb_device_path=$(dirname "$interface_path")
					while [ -n "$usb_device_path" ] && [ "$usb_device_path" != "/" ]; do
						[ -f "${usb_device_path}/idVendor" ] && [ -f "${usb_device_path}/idProduct" ] && break
						usb_device_path=$(dirname "$usb_device_path")
					done
					if [ -n "$usb_device_path" ] && [ "$usb_device_path" != "/" ]; then
						vid=$(cat "${usb_device_path}/idVendor" 2>/dev/null)
						pid=$(cat "${usb_device_path}/idProduct" 2>/dev/null)
						iface=$(cat "${interface_path}/bInterfaceNumber" 2>/dev/null)
						case ${vid}${pid} in
							8087095a) [ "$iface" = "00" ] && XMM_COUNT=$((XMM_COUNT+1)) ;;
							0e8d7126) [ "$iface" = "04" ] && XMM_COUNT=$((XMM_COUNT+1)) ;;
							0e8d7127) [ "$iface" = "06" ] && XMM_COUNT=$((XMM_COUNT+1)) ;;
						esac
					fi
				fi
			fi
			dev_num=$((dev_num+1))
		done
	done
}

detect_modems(){
	MM_LIST=$(mmcli -L 2>/dev/null)
	if [ "$MM_LIST" = "No modems were found" ] || [ -z "$MM_LIST" ]; then
		MM_COUNT=0
	else
		MM_COUNT=$(echo "$MM_LIST" | grep -c '/Modem/')
	fi
	
	count_xmm_modems

	TOTAL_MODEMS=$((MM_COUNT + XMM_COUNT))
	logger -t "$NODE" "Detected modems: $TOTAL_MODEMS"
}
# iface name
 make_ifname(){
	[ "$TOTAL_MODEMS" -eq "1" ] && ifmodemname=modem || ifmodemname=modem${mn}
}


# ============================================================
# MAIN
# ============================================================

NODE=MODEMCONFIG

do_run(){
	MWAN_IFACES=""
	mn=1 

	case $board in
		b4com,mcr100|\
		b4com,mcr200)
			TOTAL_MODEMS=0
			qmi_stuff
		;;
		*)
			detect_modems
			[ "$MM_COUNT" -gt "0" ] && {
				mm_stuff
			} || {
				disable_mm
			}

			[ "$XMM_COUNT" -gt "0" ] && xmm_stuff
		;;
	esac

	sleep 5
	sleep 30
	uci commit
	reload_config
	setup_mwan3
}


SLEEP=120
[ -f /etc/openwrt_release ] && {
	. /etc/openwrt_release
	case $DISTRIB_TARGET in
		*mt76x8*|*mt7620*|*ath79*) SLEEP=240 ;;
	esac
}

sleep $SLEEP && do_run &
